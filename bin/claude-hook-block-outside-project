#!/usr/bin/env bash

set -euo pipefail

usage() {
	local fd="${1:-2}"
	cat <<EOF >&"$fd"
Usage: claude-hook-block-outside-project

Claude Code PreToolUse hook that blocks Read/Glob/Grep access to paths
under ~/code/src/ that are outside the project root (CLAUDE_PROJECT_DIR,
fixed at launch time) and any additionalDirectories configured in Claude
Code settings.

Requires: jq

Environment:
  CLAUDE_PROJECT_DIR    Project root the access is gated against. Injected by
                        Claude Code when invoking hooks; unlike the cwd in the
                        hook payload, it does not follow the agent's cd.
  SANDBOX_PROJECT_ROOT  Fallback project root, exported by util-agent-sandbox-exec
                        at launch. Used when CLAUDE_PROJECT_DIR is unset.

This command is called automatically by Claude Code and should not be
executed manually unless for testing purposes.

Examples:
  echo '{"tool_name":"Read","tool_input":{"file_path":"/home/user/code/src/cli/foo.ts"}}' | CLAUDE_PROJECT_DIR=/home/user/code/src/github.com/user/proj claude-hook-block-outside-project
EOF
}

deny() {
	local reason="${1:-Denied by hook}"
	cat <<EOF
{"hookSpecificOutput":{"hookEventName":"PreToolUse","permissionDecision":"deny","permissionDeniedMessage":"${reason}"}}
EOF
}

extract_path() {
	local tool_name="$1" json_input="$2"

	case "${tool_name}" in
	Read) jq -r '.tool_input.file_path // empty' <<<"${json_input}" ;;
	Glob) jq -r '.tool_input.path // empty' <<<"${json_input}" ;;
	Grep) jq -r '.tool_input.path // empty' <<<"${json_input}" ;;
	*) return 0 ;;
	esac
}

resolve_dir() {
	local path="$1" base="$2" tilde='~'
	if [[ "${path}" == "${tilde}" ]]; then
		path="${HOME}"
	elif [[ "${path}" == "${tilde}/"* ]]; then
		path="${HOME}/${path:2}"
	elif [[ "${path}" != /* ]]; then
		path="${base%/}/${path}"
	fi
	realpath -ms "${path}"
}

additional_dirs() {
	local cwd="$1" file
	local files=(
		"${HOME}/.config/claude/settings.json"
		"${cwd}/.claude/settings.json"
		"${cwd}/.claude/settings.local.json"
	)
	for file in "${files[@]}"; do
		[[ -f "${file}" ]] || continue
		jq -r '[(.additionalDirectories // [])[],
			(.permissions.additionalDirectories // [])[]] | .[]' \
			"${file}" 2>/dev/null || true
	done
}

is_under() {
	local path="$1" root="$2"
	[[ "${path}" == "${root}" || "${path}" == "${root%/}/"* ]]
}

main() {
	if [[ "${1:-}" == "-h" || "${1:-}" == "--help" ]]; then
		usage 1
		return 0
	fi

	if ! command -v jq >/dev/null 2>&1; then
		exit 0
	fi

	if [ -t 0 ]; then
		echo "Error: No input data. This command should be called by Claude Code hooks." >&2
		usage
		return 1
	fi

	local json_input tool_name project_root target_path code_src dir
	json_input=$(cat)
	tool_name=$(jq -r '.tool_name // empty' <<<"${json_input}")
	project_root="${CLAUDE_PROJECT_DIR:-${SANDBOX_PROJECT_ROOT:-}}"

	[[ -z "${tool_name}" || -z "${project_root}" ]] && exit 0

	target_path=$(extract_path "${tool_name}" "${json_input}")
	[[ -z "${target_path}" ]] && exit 0

	code_src="${HOME}/code/src"
	is_under "${target_path}" "${code_src}" || exit 0
	is_under "${target_path}" "${project_root}" && exit 0

	while IFS= read -r dir; do
		[[ -z "${dir}" ]] && continue
		dir=$(resolve_dir "${dir}" "${project_root}")
		is_under "${target_path}" "${dir}" && exit 0
	done < <(additional_dirs "${project_root}")

	deny "Blocked: ${target_path} is outside the project root ${project_root} and any allowed directory"
	exit 0
}

main "$@"
