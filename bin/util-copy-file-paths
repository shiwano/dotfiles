#!/usr/bin/env bash

set -euo pipefail

usage() {
	local fd="${1:-2}"
	cat <<EOF >&"$fd"
Usage: util-copy-file-paths [dir]

Interactively select files and copy their paths to the clipboard.

Examples:
  util-copy-file-paths
  util-copy-file-paths src
EOF
}

main() {
	if [[ "${1:-}" == "--help" || "${1:-}" == "-h" ]]; then
		usage 1
		return 0
	fi

	local selected
	selected="$(FZF_PROMPT='CopyPath> ' util-select-files "$@")"
	[ -z "$selected" ] && return 0

	printf "%s" "$selected" | pbcopy
	printf "\e[36mCopied to clipboard:\e[0m\n%s\n" "$selected"
}

main "$@"
