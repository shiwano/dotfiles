#!/usr/bin/env bash

set -euo pipefail

usage() {
	local fd="${1:-2}"
	cat <<EOF >&"$fd"
Usage: vcs-copy-changed-file-paths

Interactively select changed/added/untracked Git files and copy their paths to clipboard.

Examples:
  vcs-copy-changed-file-paths
EOF
}

main() {
	if [[ "${1:-}" == "--help" || "${1:-}" == "-h" ]]; then
		usage 1
		return 0
	fi

	local selected
	selected="$(FZF_PROMPT='CopyPath> ' vcs-select-changed-files)"
	[ -z "$selected" ] && return 0

	printf "%s" "$selected" | pbcopy
	printf "\e[36mCopied to clipboard:\e[0m\n%s\n" "$selected"
}

main "$@"
