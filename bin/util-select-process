#!/usr/bin/env bash

set -euo pipefail

usage() {
	local fd="${1:-2}"
	cat <<EOF >&"$fd"
Usage: util-select-process

Interactively select processes and output their PIDs.
Shows only the current user's processes, excluding system daemons.
Sorted by start time (newest first).

Examples:
  util-select-process
  util-select-process | xargs kill
EOF
}

build_process_list() {
	local self_pid="$1"
	local current_user
	current_user="$(whoami)"
	local lsof_output
	lsof_output="$(lsof -i -P -n 2>/dev/null || true)"

	ps -U "$current_user" -eo pid,etime,args | awk -v self_pid="$self_pid" -v lsof="$lsof_output" '
	BEGIN {
		n = split(lsof, lines, "\n")
		for (i = 2; i <= n; i++) {
			line = lines[i]
			if (line == "") continue
			pid = ""
			port = ""
			nf = split(line, fields, /[[:space:]]+/)
			if (nf >= 2) pid = fields[2]
			if (nf >= 1) {
				name = fields[nf]
				if (match(name, /:[0-9]+$/)) {
					port = substr(name, RSTART + 1, RLENGTH - 1)
				}
			}
			if (pid != "" && port != "") {
				if (ports[pid] == "") {
					ports[pid] = port
				} else if (index(ports[pid], port) == 0) {
					ports[pid] = ports[pid] "," port
				}
			}
		}
	}
	function etime_to_sec(s,    parts, n, d, h, m, sec) {
		# Format: [[DD-]HH:]MM:SS
		d = 0; h = 0; m = 0; sec = 0
		if (index(s, "-") > 0) {
			split(s, parts, "-")
			d = parts[1] + 0
			s = parts[2]
		}
		n = split(s, parts, ":")
		if (n == 3) { h = parts[1]; m = parts[2]; sec = parts[3] }
		else if (n == 2) { m = parts[1]; sec = parts[2] }
		else { sec = parts[1] }
		return d * 86400 + h * 3600 + m * 60 + sec
	}
	NR == 1 { next }
	{
		pid = $1
		etime = $2
		args = ""
		for (i = 3; i <= NF; i++) {
			args = (args == "") ? $i : args " " $i
		}
		if (pid == self_pid) next
		if (args ~ /^(ps|awk|fzf|grep|lsof)( |$)/) next
		if (args ~ /\/(ps|awk|fzf|grep|lsof)( |$)/) next
		if (pid == 0 || pid == 1) next
		if (args ~ /^\/usr\/libexec\//) next
		if (args ~ /^\/System\/Library\//) next
		if (args ~ /^\/Library\/Apple\//) next
		port = (ports[pid] != "") ? ports[pid] : "-"
		sec = etime_to_sec(etime)
		count++
		rows[count] = sprintf("%-7s %-12s %s", pid, port, args)
		secs[count] = sec
	}
	END {
		# Bubble sort by elapsed time ascending (newest first)
		for (i = 1; i <= count; i++) {
			for (j = i + 1; j <= count; j++) {
				if (secs[i] > secs[j]) {
					tmp = secs[i]; secs[i] = secs[j]; secs[j] = tmp
					tmp = rows[i]; rows[i] = rows[j]; rows[j] = tmp
				}
			}
		}
		printf "%-7s %-12s %s\n", "PID", "PORT", "COMMAND"
		for (i = 1; i <= count; i++) {
			print rows[i]
		}
	}'
}

main() {
	if [[ "${1:-}" == "--help" || "${1:-}" == "-h" ]]; then
		usage 1
		return 0
	fi

	local prompt="${FZF_PROMPT:-Process> }"

	local process_list
	process_list="$(build_process_list $$)"
	[ -z "$process_list" ] && return 0

	# shellcheck disable=SC2016
	local preview='fzf-preview process $(echo {} | awk "{print \$1}")'

	local selected
	selected="$(echo "$process_list" | fzf --header-lines=1 -m --prompt "$prompt" --preview "$preview" --preview-window=down,6 || true)"
	[ -z "$selected" ] && return 0

	echo "$selected" | awk '{print $1}'
}

main "$@"
