#!/usr/bin/env bash

set -euo pipefail

usage() {
	local fd="${1:-2}"
	cat <<EOF >&"$fd"
Usage: vcs-changed-file-paths

List changed file paths (excluding deleted files) in the current jj/git repository.
Outputs one file path per line.

Examples:
  vcs-changed-file-paths
  vcs-changed-file-paths | xargs nvim-lint --lsp
EOF
}

main() {
	if [[ "${1:-}" == "-h" ]] || [[ "${1:-}" == "--help" ]]; then
		usage 1
		return 0
	fi

	if jj root >/dev/null 2>&1; then
		jj diff --no-pager --summary | grep -v -E '^D ' | cut -c3- || true
	else
		git diff --name-only --diff-filter=d HEAD || true
	fi
}

main "$@"
