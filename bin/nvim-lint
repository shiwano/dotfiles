#!/usr/bin/env bash

set -euo pipefail

usage() {
	local fd="${1:-2}"
	cat <<EOF >&"$fd"
Usage: nvim-lint [options] [file...]

Run nvim-lint on files using Neovim headless mode.
Uses the same nvim-lint configuration as your Neovim init.lua.

Options:
  --changed   Lint files changed in the current VCS (jj/git) working copy
  -h, --help  Show this help message

Arguments:
  file...     Files to lint. Use path/... for recursive directory (git-tracked text files only)

Examples:
  nvim-lint main.go
  nvim-lint --changed
  nvim-lint ./...
  nvim-lint src/...
EOF
}

expand_recursive() {
	local dir="$1"
	git grep -Il '' -- "${dir}" 2>/dev/null || true
}

is_generated_file() {
	head -n 5 "$1" 2>/dev/null |
		grep -qiE 'DO NOT EDIT|generated by|auto-generated|automatically generated|code generated|this file is generated|machine generated'
}

main() {
	local use_changed=false
	local files=()

	while [[ $# -gt 0 ]]; do
		case $1 in
		-h | --help)
			usage 1
			return 0
			;;
		--changed)
			use_changed=true
			shift
			;;
		-*)
			echo "Error: unknown option: $1" >&2
			usage
			return 1
			;;
		*)
			if [[ "$1" =~ ^(.*)/\.\.\.$ ]]; then
				local dir="${BASH_REMATCH[1]:-.}"
				local f
				while IFS= read -r f; do
					if [ -f "$f" ]; then
						files+=("$f")
					fi
				done < <(expand_recursive "$dir")
			else
				files+=("$1")
			fi
			shift
			;;
		esac
	done

	if [ "$use_changed" = true ]; then
		local changed
		changed=$(vcs-changed-file-paths)

		if [ -n "${changed}" ]; then
			local f
			while IFS= read -r f; do
				if [ -f "$f" ] && ! is_generated_file "$f"; then
					files+=("$f")
				fi
			done <<<"${changed}"
		fi
	fi

	if [ "${#files[@]}" -lt 1 ]; then
		return 0
	fi

	if ! command -v nvim >/dev/null 2>&1; then
		echo "Error: nvim command not found" >&2
		return 1
	fi

	local has_error=false
	local resolved=()

	local file
	for file in "${files[@]}"; do
		local fullpath
		fullpath=$(cd "$(dirname "$file")" && echo "$(pwd)/$(basename "$file")")

		if [ ! -f "$fullpath" ]; then
			echo "Error: file not found: ${file}" >&2
			has_error=true
			continue
		fi

		resolved+=("$fullpath")
	done

	if [ "${#resolved[@]}" -gt 0 ]; then
		local lint_cmd="require('cli').lint()"
		local nvim_args=(nvim --headless "${resolved[@]}" +"lua ${lint_cmd}")

		if ! "${nvim_args[@]}"; then
			has_error=true
		fi
	fi

	if [ "$has_error" = true ]; then
		return 1
	fi
	return 0
}

main "$@"
