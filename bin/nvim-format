#!/usr/bin/env bash

set -euo pipefail

usage() {
	local fd="${1:-2}"
	cat <<EOF >&"$fd"
Usage: nvim-format <file> [file...]

Format files using conform.nvim via Neovim headless mode.
Uses the same conform.nvim configuration as your Neovim init.lua.

Examples:
  nvim-format main.go
  nvim-format script.sh lib.lua
EOF
}

main() {
	if [[ "${1:-}" == "--help" || "${1:-}" == "-h" ]]; then
		usage 1
		return 0
	fi

	if [ "$#" -lt 1 ]; then
		usage
		return 1
	fi

	if ! command -v nvim >/dev/null 2>&1; then
		echo "Error: nvim command not found" >&2
		return 1
	fi

	local has_error=false

	local file
	for file in "$@"; do
		local fullpath
		fullpath=$(cd "$(dirname "$file")" && echo "$(pwd)/$(basename "$file")")

		if [ ! -f "$fullpath" ]; then
			echo "Error: file not found: ${file}" >&2
			has_error=true
			continue
		fi

		if ! nvim --headless "$fullpath" +"lua require('cli').format()"; then
			has_error=true
		fi
	done

	if [ "$has_error" = true ]; then
		return 1
	fi
	return 0
}

main "$@"
