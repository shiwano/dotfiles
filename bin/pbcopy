#!/usr/bin/env bash

set -euo pipefail

usage() {
	local fd="${1:-2}"
	cat <<EOF >&"$fd"
Usage: pbcopy

Copy stdin to the system clipboard.

Examples:
  echo "hello" | pbcopy
EOF
}

main() {
	if [[ "${1:-}" == "--help" || "${1:-}" == "-h" ]]; then
		usage 1
		return 0
	fi

	case "$(uname -s)" in
	Darwin)
		exec /usr/bin/pbcopy
		;;
	Linux)
		if command -v xsel >/dev/null 2>&1; then
			exec xsel --clipboard --input
		elif command -v xclip >/dev/null 2>&1; then
			exec xclip -selection clipboard
		fi
		;;
	esac

	echo "pbcopy: no clipboard command found" >&2
	return 1
}

main "$@"
