#!/usr/bin/env bash

set -euo pipefail

usage() {
	local fd="${1:-2}"
	cat <<EOF >&"$fd"
Usage: nvim-lint [options] <file> [file...]

Run nvim-lint on files using Neovim headless mode.
Uses the same nvim-lint configuration as your Neovim init.lua.

Options:
  --lsp       Also check LSP diagnostics (gopls, ts_ls, pyright, etc.)
  -h, --help  Show this help message

Examples:
  nvim-lint main.go
  nvim-lint script.sh lib.lua
  nvim-lint --lsp main.go
EOF
}

main() {
	local use_lsp=false
	local files=()

	while [[ $# -gt 0 ]]; do
		case $1 in
		-h | --help)
			usage 1
			return 0
			;;
		--lsp)
			use_lsp=true
			shift
			;;
		-*)
			echo "Error: unknown option: $1" >&2
			usage
			return 1
			;;
		*)
			files+=("$1")
			shift
			;;
		esac
	done

	if [ "${#files[@]}" -lt 1 ]; then
		usage
		return 1
	fi

	if ! command -v nvim >/dev/null 2>&1; then
		echo "Error: nvim command not found" >&2
		return 1
	fi

	local has_error=false
	local resolved=()

	local file
	for file in "${files[@]}"; do
		local fullpath
		fullpath=$(cd "$(dirname "$file")" && echo "$(pwd)/$(basename "$file")")

		if [ ! -f "$fullpath" ]; then
			echo "Error: file not found: ${file}" >&2
			has_error=true
			continue
		fi

		resolved+=("$fullpath")
	done

	if [ "${#resolved[@]}" -gt 0 ]; then
		local lint_cmd="require('cli').lint()"
		local nvim_args=(nvim --headless "${resolved[@]}" +"lua ${lint_cmd}")
		if [ "$use_lsp" != true ]; then
			nvim_args=(env NVIM_NO_LSP=1 "${nvim_args[@]}")
		fi

		if ! "${nvim_args[@]}"; then
			has_error=true
		fi
	fi

	if [ "$has_error" = true ]; then
		return 1
	fi
	return 0
}

main "$@"
