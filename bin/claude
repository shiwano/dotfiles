#!/usr/bin/env bash

set -euo pipefail

main() {
	local args=(
		--allow-write "$(realpath .)"
		--allow-write "$HOME/dotfiles/dot.config/claude"
		--allow-write "$HOME/.config/claude"
		--allow-write "$HOME/.npm"
		--allow-write "$HOME/.pub-cache"
		--allow-write "$HOME/.dart-tool"
		--allow-write "$HOME/.cargo"
		--allow-write "$HOME/.rustup"
		--allow-write "$HOME/.gem"
		--allow-write "$HOME/.bundle"
		--allow-write "$HOME/.local"
		--allow-write "$HOME/.cache"
		--allow-write "$GOPATH/pkg"
		--allow-write /tmp

		--deny-read "$HOME/.ssh"
		--deny-read "$HOME/.gnupg"
		--deny-read "$HOME/.gpg"
		--deny-read "$HOME/.config/gcloud"
		--deny-read "$HOME/.aws"
		--deny-read "$HOME/.azure"
		--deny-read "$HOME/.kube"
		--deny-read "$HOME/.netrc"
		--deny-read "$HOME/.git-credentials"
		--deny-read "$HOME/.vault-token"
		--deny-read "$HOME/.bash_history"
		--deny-read "$HOME/.zsh_history"
		--deny-read "$HOME/.mysql_history"
		--deny-read "$HOME/.psql_history"
		--deny-read "$HOME/.sqlite_history"
		--deny-read "$HOME/.pgpass"
		--deny-read "$HOME/.terraform.d"
		--deny-read "$HOME/.config/gh"
		--deny-read "$HOME/.gitlab-ci-token"
		--deny-read "$HOME/.travis"
		--deny-read "$HOME/.jenkins"
		--deny-read "$HOME/.yarnrc"
		--deny-read "$HOME/.python_history"
		--deny-read "$HOME/.emulator_console_auth_token"
		--deny-read "$(realpath .env)"
		--deny-read "$(realpath .envrc)"
		--deny-read "$(realpath secret)"
		--deny-read "$(realpath secrets)"
	)

	if [[ "$(uname)" == "Darwin" ]]; then
		args+=(
			--allow-write "$HOME/Library/Caches"
			--allow-write "$HOME/Library/Logs"
			--allow-write "$HOME/Library/Keychains"
			--allow-write /private/tmp

			--deny-read "$HOME/Desktop"
			--deny-read "$HOME/Documents"
			--deny-read "$HOME/Downloads"
			--deny-read "$HOME/Dropbox"
			--deny-read "$HOME/Applications"
			--deny-read "$HOME/jpki"
		)
		if [ -n "${HOMEBREW_PREFIX:-}" ]; then
			args+=(--allow-write "$HOMEBREW_PREFIX/Library/Homebrew/cmd/shellenv.sh")
		fi
	fi

	if [[ "$(uname)" == "Linux" ]]; then
		args+=(--allow-write "/dev/pts") # For bwrap
	fi

	if git_common_dir="$(git rev-parse --git-common-dir 2>/dev/null)"; then
		args+=(--allow-write "$(realpath "$git_common_dir")")
	fi

	if jj_root="$(jj root 2>/dev/null)"; then
		args+=(--allow-write "$jj_root/.jj")
	fi

	# Allow writing to tmux client tty for OSC 777 notifications
	if [[ -n "${TMUX:-}" ]]; then
		local client_tty
		client_tty=$(tmux display-message -p '#{client_tty}')
		args+=(--allow-write "$client_tty")
	fi

	# WSL2: deny access to Windows filesystem mounts
	if [ -n "${WSL_DISTRO_NAME:-}" ]; then
		for dir in /mnt/[a-z]; do
			[ -d "$dir" ] && args+=(--deny-read "$dir/Users")
		done
	fi

	# Redact sensitive environment variables
	local redact_patterns=(
		'*_TOKEN'
		'*_SECRET'
		'*_KEY'
		'*_PASSWORD'
		'*_CREDENTIAL'
		'*_CREDENTIALS'
	)
	local redact_allowlist=(
		'HF_TOKEN'
	)

	local pattern
	while IFS='=' read -r name _; do
		local matched=false
		for pattern in "${redact_patterns[@]}"; do
			# shellcheck disable=SC2254
			case "$name" in $pattern) matched=true && break ;; esac
		done
		if [[ "$matched" == true ]]; then
			local allowlisted=false
			for pattern in "${redact_allowlist[@]}"; do
				# shellcheck disable=SC2254
				case "$name" in $pattern) allowlisted=true && break ;; esac
			done
			if [[ "$allowlisted" == false ]]; then
				export "$name=[REDACTED]"
			fi
		fi
	done < <(env)

	exec mise exec -- util-sandbox-exec "${args[@]}" -- \
		claude --mcp-config "$HOME/.mcp-global.json" "$@"
}

main "$@"
