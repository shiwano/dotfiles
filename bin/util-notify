#!/usr/bin/env bash

set -euo pipefail

usage() {
	local fd="${1:-2}"
	cat <<EOF >&"$fd"
Usage: util-notify [OPTIONS] <message>

Send a notification via OSC 777 escape sequence.
Designed for use with Ghostty, which supports OSC 777 and automatically
suppresses notifications when the terminal is focused.
If run from within tmux, the notification is written directly to the
client tty to bypass the allow-passthrough restriction.

Options:
  -t, --title <title>    Title for the notification
  --focus                Switch to a tmux window with a pending notification
  --clear-window         Clear pending state for the current window

To auto-switch to the notifying window on terminal focus, add to tmux.conf:
  set-hook -g client-focus-in 'run-shell -b "util-notify --focus"'

To clear pending state when switching windows, add to tmux.conf:
  set-hook -g session-window-changed 'run-shell -b "util-notify --clear-window"'

Example:
  util-notify "Build completed"
  util-notify --title "Build Status" "Build completed"
  util-notify --focus
EOF
}

send_notification() {
	local title="$1" message="$2"
	if [[ -n "${TMUX:-}" ]]; then
		local client_tty
		client_tty=$(tmux display-message -p '#{client_tty}')
		printf '\e]777;notify;%s;%s\a' "$title" "$message" \
			>"$client_tty" 2>/dev/null
		if is_client_focused; then
			printf '\a' >"$client_tty" 2>/dev/null
		fi
	else
		printf '\e]777;notify;%s;%s\a' "$title" "$message" \
			>/dev/tty 2>/dev/null
	fi
}

mark_window_pending() {
	if [[ -n "${TMUX:-}" && -n "${TMUX_PANE:-}" ]]; then
		local window_target
		window_target=$(tmux display-message -p -t "$TMUX_PANE" '#{session_name}:#{window_index}')
		tmux set-option -w -t "$window_target" @notify_pending 1
	fi
}

clear_all_pending() {
	local window_id
	while IFS= read -r window_id; do
		tmux set-option -w -t "$window_id" -u @notify_pending 2>/dev/null
	done < <(tmux list-windows -a -F '#{session_name}:#{window_index}')
}

clear_window_pending() {
	if [[ -n "${TMUX:-}" ]]; then
		local window_target
		window_target=$(tmux display-message -p '#{session_name}:#{window_index}')
		tmux set-option -w -t "$window_target" -u @notify_pending 2>/dev/null
	fi
}

is_client_focused() {
	if [[ -z "${TMUX:-}" ]]; then
		return 1
	fi
	local client_flags
	client_flags=$(tmux display-message -p '#{client_flags}')
	[[ "$client_flags" == *focused* ]]
}

is_active_pane() {
	if [[ -z "${TMUX:-}" || -z "${TMUX_PANE:-}" ]]; then
		return 1
	fi
	local pane_active window_active
	pane_active=$(tmux display-message -p -t "$TMUX_PANE" '#{pane_active}')
	window_active=$(tmux display-message -p -t "$TMUX_PANE" '#{window_active}')
	[[ "$pane_active" == "1" && "$window_active" == "1" ]]
}

focus_pending_window() {
	local pending_windows=()
	local -A pending_names=()
	while IFS=$'\t' read -r window_id pending window_name; do
		if [[ "$pending" == "1" ]]; then
			pending_windows+=("$window_id")
			pending_names["$window_id"]="$window_name"
		fi
	done < <(tmux list-windows -a \
		-F '#{session_name}:#{window_index}	#{@notify_pending}	#{window_name}')

	if [[ ${#pending_windows[@]} -eq 0 ]]; then
		return 0
	fi

	if [[ ${#pending_windows[@]} -eq 1 ]]; then
		tmux select-window -t "${pending_windows[0]}"
		clear_all_pending
		return 0
	fi

	local menu_args=(-T "Switch to window")
	for target in "${pending_windows[@]}"; do
		menu_args+=("${pending_names[$target]}" ""
			"select-window -t '$target'")
	done
	tmux display-menu "${menu_args[@]}"
	clear_all_pending
}

main() {
	local title=""
	local message=""
	local focus=false

	while [[ $# -gt 0 ]]; do
		case $1 in
		-h | --help)
			usage 1
			return 0
			;;
		--focus)
			focus=true
			shift
			;;
		--clear-window)
			clear_window_pending
			return 0
			;;
		-t | --title)
			if [[ -z "${2:-}" ]]; then
				echo "Error: --title requires a value" >&2
				usage 2
				return 1
			fi
			title="$2"
			shift 2
			;;
		-*)
			echo "Error: Unknown option $1" >&2
			usage 2
			return 1
			;;
		*)
			if [[ -n "$message" ]]; then
				echo "Error: Multiple messages specified" >&2
				usage 2
				return 1
			fi
			message="$1"
			shift
			;;
		esac
	done

	if [[ "$focus" == true ]]; then
		focus_pending_window
		return 0
	fi

	if [[ -z "$message" ]]; then
		echo "Error: Message is required" >&2
		usage 2
		return 1
	fi

	if is_active_pane && is_client_focused; then
		return 0
	fi

	send_notification "$title" "$message"
	mark_window_pending
}

main "$@"
