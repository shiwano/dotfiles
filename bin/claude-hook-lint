#!/usr/bin/env bash

set -euo pipefail

# stdin から JSON を読み、file_path を抽出して nvim-lint を実行
# lint エラーがあれば exit 2 で Claude にフィードバック
main() {
	local input file_path lint_output
	input=$(cat)
	file_path=$(echo "${input}" | jq -r '.tool_input.file_path // empty')

	if [ -z "${file_path}" ] || [ ! -f "${file_path}" ]; then
		return 0
	fi

	lint_output=$(nvim-lint "${file_path}" 2>&1) || {
		echo "${lint_output}" >&2
		exit 2
	}
	return 0
}

main "$@"
