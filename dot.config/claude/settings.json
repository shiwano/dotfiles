{
  "env": {
    "CLAUDE_CODE_DISABLE_MOUSE": "1",
    "CLAUDE_CODE_NO_FLICKER": "1",
    "CLAUDE_CODE_DISABLE_FEEDBACK_SURVEY": "1",
    "DISABLE_TELEMETRY": "1",
    "DISABLE_ERROR_REPORTING": "1"
  },
  "includeCoAuthoredBy": false,
  "permissions": {
    "allow": [
      "mcp__ide__getDiagnostics",
      "mcp__codex__codex",
      "mcp__context7__resolve-library-id",
      "mcp__context7__query-docs",
      "WebFetch",
      "WebSearch",
      "Bash(cd *)",
      "Bash(echo *)",
      "Bash(cat *)",
      "Bash(ls *)",
      "Bash(find *)",
      "Bash(grep *)",
      "Bash(wc *)",
      "Bash(rg *)",
      "Bash(tree *)",
      "Bash(xargs *)",
      "Bash(basename *)",
      "Bash(head *)",
      "Bash(tail *)",
      "Bash(sort *)",
      "Bash(uniq *)",
      "Bash(cut *)",
      "Bash(diff *)",
      "Bash(mkdir *)",
      "Bash(mv *)",
      "Bash(test *)",
      "Bash(sed -n *)",
      "Bash(jq *)",
      "Bash(make test *)",
      "Bash(go get *)",
      "Bash(go build *)",
      "Bash(go test *)",
      "Bash(go list *)",
      "Bash(go vet *)",
      "Bash(go doc *)",
      "Bash(go mod graph *)",
      "Bash(go mod why *)",
      "Bash(goimports *)",
      "Bash(golangci-lint *)",
      "Bash(npm run *)",
      "Bash(bun --version *)",
      "Bash(bun add *)",
      "Bash(bun run *)",
      "Bash(bun test *)",
      "Bash(bunx tsc *)",
      "Bash(flutter analyze *)",
      "Bash(flutter test *)",
      "Bash(flutter pub deps *)",
      "Bash(cargo test *)",
      "Bash(uv *)",
      "Bash(pytest *)",
      "Bash(git -C * log *)",
      "Bash(git -C * show *)",
      "Bash(git -C * diff *)",
      "Bash(git -C * grep *)",
      "Bash(git -C * ls-files *)",
      "Bash(git -C * status *)",
      "Bash(git rm *)",
      "Bash(git mv *)",
      "Bash(git log *)",
      "Bash(git show *)",
      "Bash(git diff *)",
      "Bash(git grep *)",
      "Bash(git ls-files *)",
      "Bash(git status *)",
      "Bash(cargo build *)",
      "Bash(cargo check *)",
      "Bash(gh-pr-comments *)",
      "Bash(gh-pr-ci-failures *)",
      "Bash(gh-dependabot-alerts *)",
      "Bash(shfmt -d *)",
      "Bash(nvidia-smi *)",
      "Bash(nvim-lint *)",
      "Bash(nvim-format *)"
    ],
    "deny": [
      "Bash(env *)",
      "Bash(sh *)",
      "Bash(bash *)",
      "Bash(zsh *)",
      "Bash(sudo *)",
      "Bash(wget *)",
      "Bash(nc *)",
      "Bash(dd *)",
      "Bash(mkfs *)",
      "Bash(chown -R *)",
      "Bash(rm -rf *)",
      "Bash(mv /* *)",
      "Bash(cd /* *)",
      "Bash(> /dev/sda *)",
      "Bash(source *)",
      "Bash(git branch -D *)",
      "Bash(git branch -d *)",
      "Bash(git push *)",
      "Bash(tmux *)",
      "Bash(gh *)",
      "Bash(docker push *)",
      "Bash(uv auth *)",
      "Bash(npm publish *)",
      "Bash(brew *)",
      "Bash(mise *)",
      "Bash(gcloud *)",
      "Bash(aws *)",
      "Bash(terraform *)",
      "Bash(kubectl *)",
      "Bash(helm *)",
      "Read(id_rsa)",
      "Read(id_ed25519)",
      "Read(.env)",
      "Read(**/secret/**)",
      "Read(**/secrets/**)"
    ],
    "defaultMode": "plan",
    "additionalDirectories": [
      "~/code/pkg/mod",
      "~/.local/share/nvim/lazy",
      "~/.pub-cache",
      "~/.rustup",
      "~/.config/claude"
    ]
  },
  "hooks": {
    "Notification": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "claude-hook-notify",
            "timeout": 10
          }
        ]
      }
    ],
    "Stop": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "claude-hook-notify-stop",
            "timeout": 10
          },
          {
            "type": "command",
            "command": "claude-hook-lint-all",
            "timeout": 120
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "claude-hook-approve-compound",
            "timeout": 10
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "claude-hook-format",
            "timeout": 30
          }
        ]
      }
    ]
  },
  "enabledPlugins": {
    "gopls-lsp@claude-plugins-official": true,
    "typescript-lsp@claude-plugins-official": true,
    "pyright-lsp@claude-plugins-official": true,
    "rust-analyzer-lsp@claude-plugins-official": true,
    "lua-lsp@claude-plugins-official": true
  },
  "outputStyle": "custom",
  "alwaysThinkingEnabled": true
}
