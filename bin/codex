#!/usr/bin/env bash

set -euo pipefail

usage() {
	local fd="${1:-2}"
	cat <<EOF >&"$fd"
Usage: codex [args...]

Wrapper for codex that merges config.base.toml (shared settings)
with environment-specific [projects.*] sections.

Examples:
  codex
  codex --help
EOF
}

merge_config() {
	local base_config="${HOME}/.codex/config.base.toml"
	local config="${HOME}/.codex/config.toml"

	if [ ! -f "${base_config}" ]; then
		return 0
	fi

	local projects_toml=""

	if [ -f "${config}" ]; then
		local config_json
		config_json="$(taplo get -f "${config}" -o json)"

		# Extract projects section as TOML
		local projects_json
		projects_json="$(printf '%s' "${config_json}" | jq '{projects}')"
		if [ "$(printf '%s' "${projects_json}" | jq '.projects')" != "null" ]; then
			projects_toml="$(printf '%s' "${projects_json}" | dasel -i json -o toml)"
		fi

		# Compare non-projects sections via JSON
		local non_projects_json
		non_projects_json="$(printf '%s' "${config_json}" | jq -S 'del(.projects)')"
		local base_json
		base_json="$(taplo get -f "${base_config}" -o json | jq -S '.')"

		# Write back to base config if shared settings were changed
		if [ "${non_projects_json}" != "{}" ] && [ "${non_projects_json}" != "${base_json}" ]; then
			printf '%s' "${non_projects_json}" | dasel -i json -o toml >"${base_config}"
		fi
	fi

	# Regenerate config.toml from base + projects
	rm -f "${config}"
	if [ -n "${projects_toml}" ]; then
		printf '%s\n\n%s\n' "$(cat "${base_config}")" "${projects_toml}" >"${config}"
	else
		cp "${base_config}" "${config}"
	fi
}

main() {
	if [[ "${1:-}" == "--help" || "${1:-}" == "-h" ]]; then
		usage 1
		return 0
	fi

	merge_config

	local args=(
		--allow-write "$HOME/.codex"
	)
	exec mise exec -- util-agent-sandbox-exec "${args[@]}" -- codex "$@"
}

main "$@"
